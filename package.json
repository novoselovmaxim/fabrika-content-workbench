{
  "name": "fabrika-content-workbench",
  "version": "0.1.0",
  "private": true,
  "description": "Фабрика Контента — редакторская платформа для управления контентом",
  "main": "electron/dist/main.js",
  "workspaces": [
    "server",
    "app"
  ],
  "scripts": {
    "dev": "concurrently -n server,app -c blue,green \"npm run dev -w server\" \"npm run dev -w app\"",
    "dev:electron": "concurrently -n server,app -c blue,green \"npm run dev -w server\" \"npm run dev -w app\" \"npx wait-on http://localhost:5173 && npx electron electron/dist/main.js\"",
    "build": "npm run build -w app && npm run build -w server && tsc -p electron/tsconfig.json",
    "dist:win": "npm run build && npx electron-builder --win",
    "dist:mac": "npm run build && npx electron-builder --mac",
    "dist:linux": "npm run build && npx electron-builder --linux"
  },
  "build": {
    "appId": "com.fabrika.content.workbench",
    "productName": "Фабрика Контента",
    "directories": {
      "app": ".",
      "output": "release/electron"
    },
    "files": [
      "electron/dist/**/*",
      "server/dist/bundle.cjs"
    ],
    "extraResources": [
      { "from": "migrations", "to": "migrations" },
      { "from": "app/dist", "to": "app" }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerSidebar": "build/installerSidebar.bmp"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^34.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.0",
    "wait-on": "^8.0.0"
  }
}
