{
  "name": "fabrika-server",
  "version": "1.2.5",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/bundle.cjs --external:better-sqlite3",
    "start": "node dist/bundle.cjs",
    "db:migrate": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx database/seeds/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "drizzle-kit": "^0.30.0",
    "drizzle-orm": "^0.41.0",
    "express": "^5.1.0",
    "jimp": "^1.6.1",
    "mammoth": "^1.12.0",
    "multer": "^2.0.0",
    "pdf-parse": "^2.4.5",
    "turndown": "^7.2.4",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.19.0",
    "@yao-pkg/pkg": "^6.0.0"
  }
}
